specification {
    element missing {
        style {
            color red
            icon https://icons.getbootstrap.com/assets/icons/question-square.svg
        }
    }
    element namespace {
        style {
            icon https://github.com/kubernetes/community/raw/refs/heads/main/icons/svg/resources/labeled/ns.svg
            opacity 25%
        }
    }
    element labelgroup
    element deployment{
        style {
            icon https://github.com/kubernetes/community/raw/refs/heads/main/icons/svg/resources/labeled/deploy.svg
        }
    }
    element service{
        style {
            icon https://github.com/kubernetes/community/raw/refs/heads/main/icons/svg/resources/labeled/svc.svg
        }
    }
    element configmap{
        style {
            icon https://github.com/kubernetes/community/raw/refs/heads/main/icons/svg/resources/labeled/cm.svg
        }
    }
    element ingress{
        style {
            icon https://github.com/kubernetes/community/raw/refs/heads/main/icons/svg/resources/labeled/ing.svg
        }
    }
    tag service2service
    tag ExternalName
}